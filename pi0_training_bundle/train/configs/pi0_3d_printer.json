{
  "_comment": "Reference config — actual training args are passed on the CLI by train/train_pi0.py. This file documents the intended setup.",
  "policy": {
    "type": "pi0",
    "pretrained_path": "lerobot/pi0",
    "n_obs_steps": 1,
    "chunk_size": 50,
    "n_action_steps": 50,
    "input_features": {
      "observation.images.cam_global": { "type": "VISUAL", "shape": [3, 480, 640] },
      "observation.images.cam_wrist": { "type": "VISUAL", "shape": [3, 480, 640] },
      "observation.state": { "type": "STATE", "shape": [7] }
    },
    "output_features": {
      "action": { "type": "ACTION", "shape": [7] }
    }
  },
  "dataset": {
    "repo_id": "open_3d_printer_diversified",
    "root": "datasets/open_3d_printer_diversified",
    "local_files_only": true
  },
  "training": {
    "steps": 30000,
    "batch_size": 8,
    "lr": 2.5e-5,
    "save_freq": 5000,
    "log_freq": 100
  },
  "output_dir": "outputs/train/pi0_3d_printer"
}
